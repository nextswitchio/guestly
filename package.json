{
  "name": "guestly",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css",
    "*.scss",
    "./lib/store.ts",
    "./lib/events.ts",
    "./server.js"
  ],
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:size": "npm run build && node scripts/bundle-size-report.js",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "analyze": "node scripts/analyze-bundle.js",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "performance": "node scripts/performance-optimization.js",
    "optimize-images": "node scripts/optimize-images.js",
    "performance-fix": "node scripts/quick-performance-fixes.js"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "framer-motion": "^12.35.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^1.14.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.11.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.5.3",
    "lighthouse": "^12.8.2",
    "playwright": "^1.58.2",
    "puppeteer": "^24.39.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
