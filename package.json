{
  "name": "guestly",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css",
    "*.scss",
    "./lib/store.ts",
    "./lib/events.ts",
    "./server.js"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" node server.js",
    "build": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" next build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:size": "npm run build && node scripts/bundle-size-report.js",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" vitest --run",
    "test:watch": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" vitest",
    "analyze": "node scripts/analyze-bundle.js",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "performance": "node scripts/performance-optimization.js",
    "optimize-images": "node scripts/optimize-images.js",
    "performance-fix": "node scripts/quick-performance-fixes.js"
  },
  "dependencies": {
    "@tiptap/extension-color": "^2.10.5",
    "@tiptap/extension-image": "^2.10.5",
    "@tiptap/extension-link": "^2.10.5",
    "@tiptap/extension-placeholder": "^2.10.5",
    "@tiptap/extension-table": "^2.10.5",
    "@tiptap/extension-table-cell": "^2.10.5",
    "@tiptap/extension-table-header": "^2.10.5",
    "@tiptap/extension-table-row": "^2.10.5",
    "@tiptap/extension-text-align": "^2.10.5",
    "@tiptap/extension-text-style": "^2.10.5",
    "@tiptap/extension-underline": "^2.10.5",
    "@tiptap/pm": "^2.10.5",
    "@tiptap/react": "^2.10.5",
    "@tiptap/starter-kit": "^2.10.5",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "dompurify": "^3.1.6",
    "framer-motion": "^12.35.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^1.14.0",
    "next": "16.1.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^15.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.11.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.5.3",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.8.2",
    "playwright": "^1.58.2",
    "puppeteer": "^24.39.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
